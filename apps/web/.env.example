# Postgres (Supabase, Neon ou Vercel Postgres) — connection string com sslmode=require.
# Na Vercel (runtime serverless), use a URL do POOLER de transação (Supabase: porta 6543).
# Para db:push / db:seed (DDL), use a URL de SESSÃO/direta (Supabase: porta 5432).
# Exemplo Supabase (sessão): postgres://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Segredo usado para assinar o JWT de sessão (cookie httpOnly).
# Gerar: openssl rand -base64 48
AUTH_SECRET=troque-este-valor

# Chave AES-256-GCM do Banco de Ativos Digitais (32 bytes em hex = 64 chars).
# Gerar: openssl rand -hex 32
# ATENÇÃO: perder esta chave = perder todos os segredos criptografados. Nunca commitar.
VAULT_ENCRYPTION_KEY=troque-este-valor

# Storage de uploads (anexos de ativos e documentos).
# local       = grava em apps/web/uploads/ (apenas dev — Vercel tem FS efêmero)
# vercel_blob = Vercel Blob (produção; exige BLOB_READ_WRITE_TOKEN)
# Default: local em dev, vercel_blob quando NODE_ENV=production.
STORAGE_DRIVER=local
# Token do Vercel Blob (Vercel → Storage → Blob). Obrigatório com vercel_blob.
BLOB_READ_WRITE_TOKEN=
# Limite de upload em MB (default 25)
MAX_UPLOAD_MB=25
